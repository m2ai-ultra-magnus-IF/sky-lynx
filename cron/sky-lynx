# Sky-Lynx Continuous Improvement Agent
# Install: sudo cp /home/apexaipc/projects/sky-lynx/cron/sky-lynx /etc/cron.d/
# Verify: sudo systemctl restart cron && sudo tail -f /var/log/syslog | grep CRON

# Environment
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Run semi-weekly: Wednesdays and Sundays at 2 AM
# L5 roadmap: eventually move to event-driven (trigger on high-friction sessions)
0 2 * * 0,3 apexaipc cd /home/apexaipc/projects/sky-lynx && /home/apexaipc/projects/sky-lynx/.venv/bin/python -m sky_lynx.analyzer analyze --auto-apply >> /var/log/sky-lynx/analyzer.log 2>&1

# Refresh project manifests daily at 1 AM (lightweight health score + activity pulse)
0 1 * * * apexaipc cd /home/apexaipc/projects/sky-lynx && /home/apexaipc/projects/sky-lynx/.venv/bin/python -m sky_lynx.analyzer refresh-manifests >> /var/log/sky-lynx/manifest-refresh.log 2>&1

# Check for unresolved pipeline proposals daily at 10 AM (squawk if overdue)
0 10 * * * apexaipc cd /home/apexaipc/projects/sky-lynx && /home/apexaipc/projects/sky-lynx/.venv/bin/python -m sky_lynx.analyzer check-proposals >> /var/log/sky-lynx/proposals.log 2>&1
